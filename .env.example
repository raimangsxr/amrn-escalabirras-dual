# Production environment template.
# Copy to `.env` and adjust every value before deploying.
#
# NEVER commit `.env`. It is gitignored.

# ---- Database ----
# SQLAlchemy URL. In docker-compose this points at the `db` service.
POSTGRES_USER=escalabirras
POSTGRES_PASSWORD=replace-with-a-strong-random-password
POSTGRES_DB=escalabirras
# The compose sets DATABASE_URL automatically from the above three vars.
# For a bare-metal Postgres, set DATABASE_URL explicitly instead.

# ---- Auth (REQUIRED in production) ----
# Operator password. >= 12 chars recommended.
# Rotate by redeploy with a new value (existing JWTs stay valid until
# they expire; rotate JWT_SECRET to invalidate them).
ADMIN_PASSWORD=replace-with-a-strong-password

# HS256 signing secret. MUST be >= 32 chars of high-entropy data.
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotating this invalidates ALL live sessions.
JWT_SECRET=replace-with-a-very-long-random-secret-min-32-chars

# Session JWT lifetime in seconds (default 24h).
JWT_TTL_SECONDS=86400

# ---- API server ----
# Comma-separated list of allowed CORS origins for the FastAPI app.
# MUST be set to the public origin of the escalabirras frontend
# (e.g. https://app.example.com). The parent iframe does NOT need to
# be in this list.
CORS_ORIGINS=https://app.example.com

# CSP frame-ancestors / X-Frame-Options value. MUST be set to the
# parent app's origin in production (e.g. https://parent.example.com).
FRAME_ANCESTORS=https://parent.example.com

# Number of uvicorn workers. Tune to (2 * CPU) + 1 on a dedicated host.
API_WORKERS=2

# Uvicorn log level. Use 'warning' in production.
API_LOG_LEVEL=warning

# Host port for the API (only used by docker-compose).
API_PORT=8000